# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no git
# Senhas locais devem vir de variaveis de ambiente, cofre (Get-Secret) ou prompt seguro.

# Banco de dados
POSTGRES_DB=backoffice
POSTGRES_USER=backoffice
POSTGRES_PASSWORD=__SET_VIA_ENV_OR_VAULT__

# Cache
REDIS_PASSWORD=__SET_VIA_ENV_OR_VAULT__

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Storage
# local  = disco da VPS (padrao inicial)
# r2     = Cloudflare R2 (quando migrar)
STORAGE_ADAPTER=local

# AI Gateway / Gemini integration
# A chave deve vir obrigatoriamente do cofre local via start_local_stack.ps1.
AI_GATEWAY_ENABLED=true
AI_GATEWAY_BASE_URL=http://ai-gateway:8091
AI_GATEWAY_MODEL=gemini-2.5-flash
AI_GATEWAY_RESEARCH_PATH=/v1/research/cases
AI_GATEWAY_REQUIRE_SECRET=true

# Gemini used by the local ai-gateway service.
# A chave deve vir obrigatoriamente do cofre local via start_local_stack.ps1.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLED=true
GEMINI_GROUNDING_ENABLED=false
GEMINI_TIMEOUT_MS=30000
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Cloudflare R2 (preencher ao migrar)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=backoffice-uploads
R2_PUBLIC_BASE=
