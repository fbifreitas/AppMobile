# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no git
# Senhas locais devem vir de variaveis de ambiente, cofre (Get-Secret) ou prompt seguro.

# Banco de dados
POSTGRES_DB=backoffice
POSTGRES_USER=backoffice
POSTGRES_PASSWORD=__SET_VIA_ENV_OR_VAULT__

# Cache
REDIS_PASSWORD=__SET_VIA_ENV_OR_VAULT__

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Storage
# local  = disco da VPS (padrao inicial)
# r2     = Cloudflare R2 (quando migrar)
STORAGE_ADAPTER=local

# Cloudflare R2 (preencher ao migrar)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=backoffice-uploads
R2_PUBLIC_BASE=
