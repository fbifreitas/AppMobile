# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no git

# Banco de dados
POSTGRES_DB=backoffice
POSTGRES_USER=backoffice
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
# valor real deve vir do cofre local via Get-Secret

# Cache
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE
# valor real deve vir do cofre local via Get-Secret

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=https://seudominio.com/api

# Bootstrap inicial da plataforma para ambiente funcional local
PLATFORM_BOOTSTRAP_ENABLED=true
PLATFORM_BOOTSTRAP_TENANT_ID=tenant-platform
PLATFORM_BOOTSTRAP_TENANT_SLUG=platform
PLATFORM_BOOTSTRAP_TENANT_NAME=Platform
PLATFORM_BOOTSTRAP_ADMIN_EMAIL=platform.admin@local.test
PLATFORM_BOOTSTRAP_ADMIN_NAME=Platform Admin
# senha do PLATFORM_ADMIN bootstrap deve vir do cofre local via Get-Secret

# Storage
# local  = disco da VPS (padrao inicial)
# r2     = Cloudflare R2 (quando migrar)
STORAGE_ADAPTER=local

# Cloudflare R2 (preencher ao migrar)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=backoffice-uploads
R2_PUBLIC_BASE=
